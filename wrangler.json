{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "growinglaughs",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    "growinglaughs.com/*",
    "www.growinglaughs.com/*"
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "none"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "domains-db",
      "database_id": "b41e909b-ad01-4fd5-84ca-d8d014706942"
    }
  ],
  "ai": {
    "binding": "AI"
  }

